<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport de Tournée - {{tourCode}}</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; line-height: 1.6; padding: 20px; }
        .header { text-align: center; border-bottom: 2px solid #4a7c2c; padding-bottom: 10px; margin-bottom: 20px; }
        .header h1 { color: #4a7c2c; margin: 0; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; background: #f9f9f9; padding: 15px; border-radius: 8px; }
        .section-title { background: #4a7c2c; color: white; padding: 8px 15px; border-radius: 4px; margin-top: 25px; margin-bottom: 10px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f2f2f2; font-weight: 600; }
        .statut-ok { color: #2e7d32; font-weight: bold; }
        .statut-probleme { color: #c62828; font-weight: bold; }
        .statut-absent { color: #757575; }
        .footer { margin-top: 40px; text-align: center; font-size: 0.9em; color: #777; border-top: 1px solid #ddd; padding-top: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>RAPPORT DE TOURNÉE</h1>
        <p>OliveRAR - Gestion de Récolte</p>
    </div>

    <div class="info-grid">
        <div><strong>Code Tournée :</strong> {{tourCode}}</div>
        <div><strong>Date :</strong> {{date}}</div>
        <div><strong>Chef de Récolte :</strong> {{chefNom}}</div>
        <div><strong>Production Totale :</strong> {{production.quantite}} {{production.unite}}</div>
    </div>

    <div class="section-title">PRÉSENCE DES OUVRIERS</div>
    <table>
        <thead>
            <tr>
                <th>Nom de l'Ouvrier</th>
                <th>Statut</th>
                <th>Heure de Pointage</th>
            </tr>
        </thead>
        <tbody>
            {{#each presences}}
            <tr>
                <td>{{nom}}</td>
                <td><span class="statut-{{statut}}">{{statut}}</span></td>
                <td>{{heure}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="section-title">VÉRIFICATION DU MATÉRIEL</div>
    <table>
        <thead>
            <tr>
                <th>Ressource / Unité</th>
                <th>État Global</th>
                <th>Notes / Incidents</th>
            </tr>
        </thead>
        <tbody>
            {{#each materiel}}
            <tr>
                <td>{{nom}}</td>
                <td><span class="statut-{{etat}}">{{etat}}</span></td>
                <td>{{note}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    {{#if notes}}
    <div class="section-title">NOTES ET INCIDENTS GLOBAUX</div>
    <div style="background: #fff; border: 1px solid #ddd; padding: 15px; border-radius: 4px;">
        {{notes}}
    </div>
    {{/if}}

    <div class="footer">
        Document généré automatiquement par OliveRAR Platform le {{date}}.<br>
        © 2026 Cooperative Agricole - Tous droits réservés.
    </div>
</body>
</html>
